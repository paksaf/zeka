# Zeka local AI keys (loaded via flutter_dotenv at app startup).
# Pick whichever provider you have a key for — the app uses them in
# order DeepSeek → OpenAI → Anthropic. Leave the rest blank.
#
# Without ANY of these the app still runs — calculator + converter
# work fully offline. Only the AI tab needs a key.

DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
