<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Voice (Hey Zeka) needs the mic. Without RECORD_AUDIO the
         speech_to_text plugin silently fails to initialise. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- speech_to_text consults the system speech recogniser via
         intent; on Android 11+ this requires a queries entry, declared
         below. -->

    <!-- Android TV (Leanback) support. Setting both features to
         required="false" means a single APK installs on phones AND TVs:
         phones ignore the leanback hint, TVs don't reject for the
         missing touchscreen. Without these, Sony Bravia + Android TV
         install the APK but hide it from the Apps row. -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <!-- Mic feature is optional too — phones have it, TVs don't, this
         keeps the APK installable everywhere. -->
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:label="zeka"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:banner="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <!-- Phone / tablet launcher entry -->
                <category android:name="android.intent.category.LAUNCHER"/>
                <!-- Android TV (Leanback) launcher entry. Without this,
                     Sony Bravia's home row won't surface the app even
                     though `adb install` succeeded. -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Required on Android 11+ so speech_to_text can discover
             the system speech recogniser. Without this, plugin
             initialise() returns false on a fresh install and the
             mic icon does nothing when tapped. -->
        <intent>
            <action android:name="android.speech.RecognitionService"/>
        </intent>
        <!-- flutter_tts discoverability -->
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE"/>
        </intent>
    </queries>
</manifest>
